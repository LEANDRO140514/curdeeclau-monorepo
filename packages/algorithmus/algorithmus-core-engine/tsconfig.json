{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmitOnError": true,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/app/api/**",
    "src/demo/**",
    "src/tests/**"
  ]
}
