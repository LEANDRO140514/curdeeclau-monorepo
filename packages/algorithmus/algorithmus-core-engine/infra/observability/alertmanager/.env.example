# Copiar a .env (no commitear) y usar con envsubst al generar alertmanager.yml efectivo.
# Ver README.md

ALERTMANAGER_SLACK_WARNING_WEBHOOK=https://hooks.slack.com/services/REPLACE/ME/WARNING
ALERTMANAGER_SLACK_CRITICAL_WEBHOOK=https://hooks.slack.com/services/REPLACE/ME/CRITICAL
# Plataforma / alertas tenant_id=_global (ej. NoTraffic)
ALERTMANAGER_SLACK_PLATFORM_WEBHOOK=https://hooks.slack.com/services/REPLACE/ME/PLATFORM

ALERTMANAGER_SMARTHOST=smtp.example.com:587
ALERTMANAGER_EMAIL_FROM=alerts@example.com
ALERTMANAGER_EMAIL_TO=oncall@example.com
ALERTMANAGER_EMAIL_AUTH_USERNAME=
ALERTMANAGER_EMAIL_AUTH_PASSWORD=
