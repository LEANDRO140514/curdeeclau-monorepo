# Copy to `.env` for local development. Required in production unless noted.
#
# Runtime principal (Express + worker): ver ADR-006 en docs/brain/ADR-006-postgres-migration.md

# PostgreSQL — obligatorio para createAppContext: pool `pg`, IdentityManager + Orchestrator vía LeadsRepository
DATABASE_URL=postgres://user:password@host:5432/dbname

# Supabase — SOLO legado (GHL webhook Next + supabase_client.ts). No usado por el core path principal.
# Ver ADR-006. Descomentar solo si ese route sigue desplegado y apunta a Supabase.
# SUPABASE_URL=https://xxxx.supabase.co
# PRIMA_DONNA_SUPABASE_URL=https://xxxx.supabase.co
# PRIMA_DONNA_SUPABASE_ANON_KEY=
# PRIMA_DONNA_SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (embeddings + LLM según config)
OPENAI_API_KEY=

# Pinecone: API key + index host (ej. https://tu-indice-xxxx.svc.aped-4627-b74a.pinecone.io)
PINECONE_API_KEY=
PINECONE_INDEX_HOST=

# Opcional: dimensión del índice (default 1536 si coincide con el embedding)
# PINECONE_DIMENSION=1536

# YCloud (WhatsApp): API key + número de origen (E.164, ej. +34911222333)
YCLOUD_API_KEY=
YCLOUD_WHATSAPP_FROM=

# Prometheus (default on). Set to false to disable /metrics and NoopMetrics.
# METRICS_ENABLED=false

# Redis — required in production (`NODE_ENV=production`). If unset in dev, defaults to redis://localhost:6379
REDIS_URL=redis://localhost:6379
